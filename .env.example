# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional Postgres URL (for Neon or any PG-compatible host).
# If not provided, the app runs with local JSON fallback storage.
DATABASE_URL=""

# Optional frontend/backend port hints. Both Vite and Express will probe for an open port.
PORT="3000"
VITE_PORT="5173"

# Optional CORS/session settings for split frontend/backend dev.
CORS_ORIGIN="http://localhost:5173"
SESSION_COOKIE_DOMAIN=""
SESSION_TTL_SECONDS="604800"
