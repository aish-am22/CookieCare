# Frontend (Vercel) - absolute URL of the backend API (Render)
VITE_API_BASE_URL="https://cookiecare-api.onrender.com"

# Backend (Render) - optional AI and database integrations
GEMINI_API_KEY="MY_GEMINI_API_KEY"
DATABASE_URL="******host:5432/dbname"

# Backend CORS allow-list (comma-separated)
CORS_ORIGIN="https://cookiecare.vercel.app,http://localhost:5173"

# Backend runtime mode
NODE_ENV="production"
SERVE_STATIC_FRONTEND="false"

# Optional deterministic scanner demo fixtures
COOKIECARE_DEMO_MODE="true"
